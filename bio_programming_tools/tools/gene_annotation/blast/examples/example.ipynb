   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Results exported to example_output\n"
     ]
    }
   ],
   "source": [
    "output_dir = Path(\"./example_output\")\n",
    "\n",
    "result.export(name=\"local_blast_results\", export_path=output_dir, file_format=\"csv\")\n",
    "online_result.export(name=\"online_blast_results\", export_path=output_dir, file_format=\"csv\")\n",
    "print(f\"Results exported to {output_dir}\")"
   ]
