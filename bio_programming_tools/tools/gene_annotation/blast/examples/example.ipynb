   "source": [
    "# Use the same hemoglobin beta sequence as the local search\n",
    "inputs = OnlineBlastInput(query=query_seq)\n",
    "config = OnlineBlastConfig(\n",
    "    program=\"blastp\",\n",
    "    database=\"swissprot\",\n",
    "    max_hits=5,\n",
    ")\n",
    "\n",
    "online_result = online_blast(inputs, config)\n",
    "print(f\"Found {online_result.num_hits} hits\")\n",
    "online_result.results_df"
   ]
  },
