# bio-programming-tools configuration
# Copy to .bpt.env and edit. Environment variables override these values.

# Where to store model weights. Options:
#   (unset)         — repo-local model_cache/ directory (default, survives env rebuilds)
#   /absolute/path  — shared directory (recommended for labs/HPC)
#   IN_ENV          — each tool stores weights in its own venv (legacy)
#   NONE            — pass through existing env vars (HF_HOME, etc.)
# BPT_MODEL_CACHE=/path/to/shared/weights
